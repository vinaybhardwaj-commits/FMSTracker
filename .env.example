# Vercel Postgres / Neon (auto-injected by `vercel env pull`)
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_URL_NO_SSL=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=
POSTGRES_PGHOST_UNPOOLED=
POSTGRES_PGPASSWORD=

# Vercel Blob (auto-injected by `vercel env pull`)
BLOB_READ_WRITE_TOKEN=

# FMSTracker — admin PIN bcrypt hash. Set via Vercel dashboard; copy locally.
# Generate from a 4-digit PIN with: node -e 'console.log(require("bcryptjs").hashSync("YOUR_PIN", 10))'
FMS_ADMIN_PIN_HASH=

# FMSTracker — admin session cookie HMAC secret. Min 32 random chars.
# Generate locally with: openssl rand -hex 32
FMS_SESSION_SECRET=

# Vercel Cron — shared secret for /api/cron/* endpoints (Phase 2)
CRON_SECRET=
