# Vercel Postgres (auto-injected by `vercel env pull`)
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# Vercel Blob (auto-injected by `vercel env pull`)
BLOB_READ_WRITE_TOKEN=

# FMSTracker — admin PIN bcrypt hash. Generate with `pnpm tsx scripts/hash-pin.ts <pin>`
FMS_ADMIN_PIN_HASH=

# Vercel Cron — shared secret for /api/cron/* endpoints
CRON_SECRET=
